# The first milestone runs without external services or API keys.
# Add provider keys here later; never commit the real .env file.
OPENAI_API_KEY=
SCHOLARSHIP_DB_PATH=data/scholarships.db

# Optional search API discovery. The app works with curated/RSS sources when disabled.
SEARCH_PROVIDER=none
SEARCH_API_KEY=
GOOGLE_CSE_ID=

# Optional discovery-summary email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_STARTTLS=true
